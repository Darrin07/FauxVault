# --- Frontend Settings ---
# Set to 'false' to use the real Express backend
# Set to 'true' (default) to use in-memory mock data
VITE_USE_MOCK=true

# API Base URL (usually handled by Vite proxy, but can be overridden)
VITE_API_BASE_URL=/api

# --- Database ---
# Used by both the Postgres container and the Express app
POSTGRES_USER=fauxvault_user
POSTGRES_PASSWORD=fauxvault_pass
POSTGRES_DB=fauxvault

# Connection target (DB_HOST=db for Docker, localhost for manual setup)
DB_HOST=db
DB_PORT=5432

# --- Auth ---
JWT_SECRET=change_me_in_production
