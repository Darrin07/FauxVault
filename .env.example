# --- Frontend (Vite) ---
# Set to 'false' to use the real Express backend.
# Set to 'true' (default) to use in-memory mock data.
VITE_USE_MOCK=true

# API base URL (usually handled by Vite proxy, but can be overridden).
VITE_API_BASE_URL=/api

# --- Docker / Postgres Initialization ---
# These values initialize the Postgres container and are also reused
# by the Express app when it connects to the database.
POSTGRES_USER=fauxvault_user
POSTGRES_PASSWORD=fauxvault_pass
POSTGRES_DB=fauxvault

# --- App Database Connection ---
# Use DB_HOST=db when the app runs inside Docker Compose.
# Use DB_HOST=localhost when running tests from the host machine
# against the Dockerized Postgres instance.
DB_HOST=db
DB_PORT=5432

# --- Auth ---
JWT_SECRET=change_me_in_production
