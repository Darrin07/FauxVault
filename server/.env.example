# --- Server Settings ---
PORT=3001
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=24h
BCRYPT_SALT_ROUNDS=10
NODE_ENV=development

# --- Database Credentials ---
# These names match server/src/config/index.js.
POSTGRES_DB=fauxvault
POSTGRES_USER=fauxvault_user
POSTGRES_PASSWORD=fauxvault_pass

# --- Database Connection Target ---
# Use DB_HOST=db when the server runs inside Docker Compose.
# Use DB_HOST=localhost when running the server or tests from the host.
DB_HOST=localhost
DB_PORT=5432
